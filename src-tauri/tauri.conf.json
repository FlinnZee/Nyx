{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Nyx",
  "version": "0.4.0",
  "identifier": "com.drv0id.nyx",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Nyx",
        "width": 1200,
        "height": 820,
        "minWidth": 940,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#07070d",
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --autoplay-policy=no-user-gesture-required --use-fake-ui-for-media-stream"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "TK NiRMAL (dr.v0id)",
    "copyright": "© 2026 TK NiRMAL (dr.v0id). All rights reserved.",
    "category": "SocialNetworking",
    "shortDescription": "Nyx — futuristic messaging.",
    "longDescription": "Nyx is a fluid, futuristic messaging experience: chats, voice notes, photo & file sharing, and voice/video calls in an elegant Midnight Aurora interface.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
